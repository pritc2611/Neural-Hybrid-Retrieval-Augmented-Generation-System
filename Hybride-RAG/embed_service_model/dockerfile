# --- Stage 1: Build Stage ---
FROM python:3.10-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Install build dependencies (needed for numpy/transformers if wheels aren't available)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

# Create venv and install dependencies
# We install torch first from the CPU index to ensure it doesn't pull the GPU version later
RUN python -m venv /opt/venv && \
    /opt/venv/bin/pip install --upgrade pip && \
    /opt/venv/bin/pip install -r requirements.txt

# --- Stage 2: Runtime Stage ---
FROM python:3.10-slim

# Create a non-root user
RUN useradd -m appuser
WORKDIR /app

# Copy the venv from builder
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy app code
COPY --chown=appuser:appuser embed_service.py .
# If you use a .env file, uncomment the next line, or better yet, pass env vars at runtime
# COPY --chown=appuser:appuser .env .

USER appuser

EXPOSE 8000

CMD ["uvicorn", "embed_service:app", "--host", "0.0.0.0", "--port", "8000"]